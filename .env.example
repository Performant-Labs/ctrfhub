# CTRFHub — Environment Variables
#
# Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#   # then edit .env with secrets
#
# `.env` is gitignored. `.env.example` is committed and serves as the
# canonical list of expected variables. New variables get a placeholder
# entry here as they're introduced.
#
# Variables are grouped by concern. Each variable is marked:
#   REQUIRED:             Must be set before the app starts.
#   REQUIRED (Postgres):  Must be set when using PostgreSQL (compose.yml / compose.dev.yml).
#   REQUIRED (SQLite):    Must be set when using SQLite (compose.sqlite.yml).
#   REQUIRED (S3):        Must be set when ARTIFACT_STORAGE=s3.
#   OPTIONAL (default: …) Has a sensible default; only set to override.

# =============================================================================
# Core — required for all deployment modes
# =============================================================================

# REQUIRED: Min 32-char random string; signs session cookies.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# REQUIRED: Public base URL of this CTRFHub instance (e.g. https://ctrfhub.example.com).
# Used for auth redirects, outbound webhook payloads, and canonical link generation.
PUBLIC_URL=http://localhost:3000

# =============================================================================
# Database — choose one mode
# =============================================================================

# REQUIRED (Postgres): PostgreSQL connection string.
# Used by compose.yml (prod) and compose.dev.yml (dev).
# Example: postgresql://ctrfhub:changeme@db:5432/ctrfhub
DATABASE_URL=postgresql://ctrfhub:changeme@db:5432/ctrfhub

# OPTIONAL (default: /data/ctrfhub.db): Path inside the container for the
# SQLite database file. Used by compose.sqlite.yml.
# When this is set and DATABASE_URL is unset, the app runs in SQLite mode.
SQLITE_PATH=/data/ctrfhub.db

# REQUIRED (Postgres, db service only): PostgreSQL superuser credentials.
# These are passed to the postgres:16-alpine container, not to the app.
POSTGRES_USER=ctrfhub
POSTGRES_PASSWORD=changeme

# =============================================================================
# Server
# =============================================================================

# OPTIONAL (default: 3000): HTTP port the Fastify server listens on inside
# the container.
PORT=3000

# OPTIONAL (default: info): Log verbosity. One of: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# Event Bus
# =============================================================================

# OPTIONAL (default: memory): Event bus transport.
# memory — in-process (single-node MVP, no Redis required)
# redis  — Redis Pub/Sub (required for multi-node SSE delivery)
EVENT_BUS=memory

# REQUIRED when EVENT_BUS=redis: Redis connection URL.
# Example: redis://redis:6379
REDIS_URL=

# =============================================================================
# AI Features
# =============================================================================

# OPTIONAL: AI provider. One of: openai | anthropic | groq
# When unset, all AI features are hidden in the UI.
AI_PROVIDER=

# REQUIRED when AI_PROVIDER is set: API key for the chosen provider.
AI_API_KEY=

# OPTIONAL: Override the default model for the chosen provider.
# Example: gpt-4o-mini
AI_MODEL=

# OPTIONAL (default: off): Infrastructure-level kill switch for managed-provider
# AI calls. Even when AI_PROVIDER and AI_API_KEY are set, no calls are made
# unless this is "on" AND the org admin has acknowledged the per-org consent dialog.
# One of: off | on
AI_CLOUD_PIPELINE=off

# =============================================================================
# Artifact Storage
# =============================================================================

# OPTIONAL (default: local): Artifact storage backend. One of: local | s3
ARTIFACT_STORAGE=local

# OPTIONAL (default: /data/artifacts): Root path for local artifact storage
# inside the container. Only used when ARTIFACT_STORAGE=local.
ARTIFACT_LOCAL_PATH=/data/artifacts

# OPTIONAL: Separate public origin for serving user-uploaded artifacts.
# Provides cookie-jar isolation (GitHub-grade XSS defence). When unset,
# artifacts serve from the main CTRFHub origin with iframe sandbox defence.
# Example: https://artifacts.ctrfhub.example.com
ARTIFACT_PUBLIC_URL=

# OPTIONAL (default: https://trace.playwright.dev): Comma-separated origins
# allowed to fetch artifact URLs cross-origin. Required for Playwright Trace
# Viewer integration.
ARTIFACT_CORS_ORIGINS=https://trace.playwright.dev

# REQUIRED (S3): S3-compatible endpoint URL.
# Example: https://s3.amazonaws.com or a MinIO URL.
S3_ENDPOINT=

# REQUIRED (S3): Bucket name for artifact storage.
S3_BUCKET=

# REQUIRED (S3): Access key ID.
S3_KEY=

# REQUIRED (S3): Secret access key.
S3_SECRET=

# =============================================================================
# Ingest Limits
# =============================================================================

# OPTIONAL (default: 10mb): Max size of the CTRF JSON field in a multipart
# ingest request. Protects the event loop from large JSON.parse() calls.
MAX_CTRF_JSON_SIZE=10mb

# OPTIONAL (default: 1gb): Max total size of a single multipart ingest
# request (JSON + all artifact file parts).
MAX_ARTIFACT_SIZE_PER_RUN=1gb

# =============================================================================
# Data Retention
# =============================================================================

# OPTIONAL (default: 0 3 * * *): Cron schedule for the nightly retention sweep.
# Default is 03:00 UTC. Trigger time is always UTC regardless of DEFAULT_TIMEZONE.
RETENTION_CRON_SCHEDULE=0 3 * * *

# =============================================================================
# Timezone
# =============================================================================

# OPTIONAL (default: UTC): Default IANA timezone identifier.
# Fallback when neither user nor org timezone is set. Only IANA zone names
# accepted (e.g. America/Los_Angeles, Europe/Berlin); abbreviations like
# PST / IST are rejected at boot.
DEFAULT_TIMEZONE=UTC

# =============================================================================
# Webhooks
# =============================================================================

# OPTIONAL (default: false): Allow outbound webhooks to target private IP
# ranges (RFC 1918, loopback, link-local). Off by default to block SSRF.
ALLOW_PRIVATE_WEBHOOK_DESTINATIONS=false

# OPTIONAL (default: false): Allow outbound webhooks to use http:// URLs.
# Intended for local development only.
ALLOW_INSECURE_WEBHOOK_DESTINATIONS=false

# =============================================================================
# Tugboat (CI-003 — per-PR preview environments)
# =============================================================================

# OPTIONAL: Tugboat API token for polling preview status in CI.
# Obtained from https://dashboard.tugboatqa.com → Account → Access Tokens.
TUGBOAT_API_TOKEN=
