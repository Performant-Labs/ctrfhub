{
  "name": "ctrfhub",
  "version": "0.1.0",
  "description": "CTRF-native self-hosted test reporting dashboard",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run assets:build",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:int": "vitest run src/__tests__/integration",
    "test:e2e": "playwright test -c e2e/playwright.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate:pg": "mikro-orm schema:update --run --config ./src/mikro-orm.config.pg.ts",
    "migrate:sqlite": "mikro-orm schema:update --run --config ./src/mikro-orm.config.sqlite.ts",
    "schema:emit:pg": "mikro-orm schema:update --dump --config ./src/mikro-orm.config.pg.ts",
    "schema:emit:sqlite": "mikro-orm schema:update --dump --config ./src/mikro-orm.config.sqlite.ts",
    "schema:update:pg": "mikro-orm schema:update --run --config ./src/mikro-orm.config.pg.ts",
    "schema:update:sqlite": "mikro-orm schema:update --run --config ./src/mikro-orm.config.sqlite.ts",
    "css:dev": "npx @tailwindcss/cli -i src/assets/input.css -o src/assets/tailwind.css --watch",
    "css:build": "npx @tailwindcss/cli -i src/assets/input.css -o src/assets/tailwind.css --minify",
    "client:build": "node scripts/copy-vendor-assets.mjs",
    "assets:build": "npm run css:build && npm run client:build",
    "assets:dev": "npx concurrently \"npm run css:dev\" \"tsx watch --clear-screen=false scripts/copy-vendor-assets.mjs\"",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/copy-vendor-assets.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@better-auth/api-key": "^1.6.9",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.5.0",
    "@fastify/type-provider-zod": "^1.0.0",
    "@fastify/view": "^11.0.0",
    "@mikro-orm/cli": "^7.0.0",
    "@mikro-orm/core": "^7.0.0",
    "@mikro-orm/migrations": "^7.0.0",
    "@mikro-orm/postgresql": "^7.0.0",
    "@mikro-orm/sqlite": "^7.0.0",
    "alpinejs": "^3.15.12",
    "better-auth": "^1.0.0",
    "eta": "^3.5.0",
    "fastify": "^5.5.0",
    "flowbite": "^4.0.1",
    "groq-sdk": "^1.1.0",
    "htmx.org": "^2.0.10",
    "idiomorph": "^0.7.4",
    "openai": "^6.34.0",
    "openapi-types": "^12.1.0",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/cli": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "playwright-ctrf-json-reporter": "^0.0.29",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
